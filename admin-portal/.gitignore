# admin-portal specific gitignore

# Node deps
node_modules/

# Next.js build output
.next/
out/

# Production build
build/
dist/

# Local env files
.env*

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS files
.DS_Store

# Lockfiles (if the monorepo uses a different manager, you may want to keep one)
# Uncomment if you want to ignore specific lockfiles
# package-lock.json
# yarn.lock
# pnpm-lock.yaml


# TypeScript build info
*.tsbuildinfo
